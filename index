<!DOCTYPE html>
<html lang="en" dir="ltr" id="root">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ENJO — Partner Onboarding Questionnaire</title>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&family=Cairo:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
  :root { --navy:#0D2233; --teal:#306F7E; --cyan:#7FD6E7; --cream:#F6F8F7; --border:#D0DFE3; --muted:#5A8A96; }

  body { font-family:'Montserrat',Arial,sans-serif; background:var(--cream); color:var(--navy); font-size:14px; line-height:1.6; }
  body.ar { font-family:'Cairo',Arial,sans-serif; direction:rtl; }
  body.en .lang-ar { display:none !important; }
  body.ar .lang-en { display:none !important; }

  /* HEADER */
  .header { background:var(--navy); padding:22px 48px; display:flex; align-items:center; justify-content:space-between; gap:16px; }
  .header-logo img { height:50px; width:auto; display:block; }
  .header-right { display:flex; align-items:center; gap:18px; }
  .header-title { text-align:right; }
  body.ar .header-title { text-align:left; }
  .header-title h1 { font-size:11px; font-weight:700; color:var(--cyan); text-transform:uppercase; letter-spacing:2px; margin-bottom:2px; }
  .header-title p { font-size:10px; color:rgba(246,248,247,0.45); }

  /* LANG TOGGLE */
  .lang-toggle { display:flex; background:rgba(255,255,255,0.1); border-radius:20px; padding:3px; gap:2px; }
  .lang-toggle button { border:none; background:transparent; color:rgba(246,248,247,0.5); font-family:inherit; font-size:11px; font-weight:700; padding:5px 14px; border-radius:16px; cursor:pointer; transition:all 0.2s; letter-spacing:0.5px; }
  .lang-toggle button.active { background:var(--teal); color:#fff; }

  /* HERO */
  .hero { background:var(--teal); padding:30px 48px; }
  .hero h2 { font-size:21px; font-weight:800; color:#fff; margin-bottom:8px; }
  .hero p { font-size:13px; color:rgba(246,248,247,0.80); max-width:640px; line-height:1.8; }

  /* BODY */
  .body { max-width:800px; margin:0 auto; padding:40px 48px 80px; }

  /* NOTE BOX */
  .note-box { background:rgba(48,111,126,0.07); border-left:3px solid var(--cyan); border-radius:0 8px 8px 0; padding:14px 18px; margin-bottom:36px; font-size:12px; color:#1E5564; line-height:1.8; }
  body.ar .note-box { border-left:none; border-right:3px solid var(--cyan); border-radius:8px 0 0 8px; }
  .note-box strong { color:var(--teal); }

  /* SECTION */
  .section { margin-bottom:48px; }
  .section-header { display:flex; align-items:center; gap:12px; margin-bottom:26px; padding-bottom:12px; border-bottom:2px solid var(--teal); }
  .section-num { background:var(--teal); color:#fff; width:29px; height:29px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:12px; font-weight:700; flex-shrink:0; }
  .section-header h3 { font-size:13px; font-weight:700; color:var(--navy); text-transform:uppercase; letter-spacing:1.2px; }
  body.ar .section-header h3 { text-transform:none; letter-spacing:0; font-size:14px; }

  /* QUESTION */
  .question { margin-bottom:22px; }
  .question label.qlabel { display:block; font-size:11px; font-weight:700; color:var(--teal); text-transform:uppercase; letter-spacing:0.8px; margin-bottom:6px; }
  body.ar .question label.qlabel { text-transform:none; letter-spacing:0; font-size:13px; }
  .hint { font-size:11px; color:var(--muted); font-style:italic; margin-bottom:8px; display:block; }
  body.ar .hint { font-style:normal; font-size:12px; }
  .optional-tag { display:inline-block; font-size:9px; font-weight:600; color:var(--muted); background:rgba(48,111,126,0.1); border-radius:10px; padding:1px 7px; margin-left:5px; text-transform:uppercase; letter-spacing:0.3px; vertical-align:middle; }
  body.ar .optional-tag { font-size:10px; text-transform:none; margin-left:0; margin-right:5px; }

  /* INPUTS */
  .answer-line { width:100%; border:none; border-bottom:1.5px solid var(--border); background:transparent; padding:8px 0; font-family:inherit; font-size:13px; color:var(--navy); outline:none; transition:border-color 0.2s; }
  .answer-line:focus { border-bottom-color:var(--teal); }
  .answer-area { width:100%; border:1.5px solid var(--border); border-radius:8px; background:#fff; padding:10px 14px; font-family:inherit; font-size:13px; color:var(--navy); outline:none; resize:vertical; min-height:80px; transition:border-color 0.2s; }
  .answer-area:focus { border-color:var(--teal); }

  /* GRID */
  .two-col { display:grid; grid-template-columns:1fr 1fr; gap:18px 36px; }

  /* PILLS */
  .pill-group { display:flex; flex-wrap:wrap; gap:8px; margin-top:6px; }
  .pill { display:flex; align-items:center; gap:7px; background:#fff; border:1.5px solid var(--border); border-radius:20px; padding:6px 14px; cursor:pointer; font-size:12px; font-weight:500; color:var(--navy); transition:border-color 0.2s; user-select:none; }
  .pill:hover { border-color:var(--teal); }
  .pill input { accent-color:var(--teal); width:13px; height:13px; flex-shrink:0; }

  /* SUBMIT */
  .submit-wrap { margin-top:48px; padding-top:32px; border-top:2px solid var(--border); display:flex; align-items:center; justify-content:space-between; gap:16px; flex-wrap:wrap; }
  .submit-note { font-size:11px; color:var(--muted); line-height:1.6; max-width:420px; }
  .btn-submit { background:var(--teal); color:#fff; border:none; border-radius:10px; padding:14px 36px; font-family:inherit; font-size:14px; font-weight:700; cursor:pointer; letter-spacing:0.3px; transition:background 0.2s, transform 0.1s; }
  .btn-submit:hover { background:#255f6d; }
  .btn-submit:active { transform:scale(0.98); }
  body.ar .submit-wrap { flex-direction:row-reverse; }

  /* SUCCESS */
  .success-overlay { display:none; position:fixed; inset:0; background:rgba(13,34,51,0.85); z-index:999; align-items:center; justify-content:center; }
  .success-overlay.show { display:flex; }
  .success-card { background:#fff; border-radius:16px; padding:48px 40px; text-align:center; max-width:440px; width:90%; }
  .success-icon { font-size:48px; margin-bottom:16px; }
  .success-card h2 { font-size:20px; font-weight:800; color:var(--navy); margin-bottom:8px; }
  .success-card p { font-size:13px; color:var(--muted); line-height:1.7; margin-bottom:24px; }
  .success-card .btn-close { background:var(--teal); color:#fff; border:none; border-radius:8px; padding:11px 28px; font-family:inherit; font-size:13px; font-weight:700; cursor:pointer; }

  /* FOOTER */
  .footer { background:var(--navy); padding:26px 48px; display:flex; justify-content:space-between; align-items:center; gap:20px; }
  body.ar .footer { flex-direction:row-reverse; }
  .footer-brand { font-size:12px; color:rgba(246,248,247,0.45); }
  .footer-brand strong { color:var(--cyan); display:block; font-size:14px; font-weight:700; margin-bottom:2px; }
  .footer-contact { text-align:right; font-size:11px; color:rgba(246,248,247,0.45); line-height:2; }
  body.ar .footer-contact { text-align:left; }
  .footer-contact a { color:var(--cyan); text-decoration:none; }

  @media print {
    .header,.hero,.footer,.section-num,.note-box,.pill,.btn-submit { -webkit-print-color-adjust:exact; print-color-adjust:exact; }
    .lang-toggle,.submit-wrap { display:none; }
  }
</style>
</head>
