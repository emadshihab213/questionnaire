<script>
function setLang(lang) {
  document.getElementById('root').lang = lang;
  document.getElementById('root').dir = lang === 'ar' ? 'rtl' : 'ltr';
  document.body.className = lang;
  document.getElementById('btn-en').className = lang === 'en' ? 'active' : '';
  document.getElementById('btn-ar').className = lang === 'ar' ? 'active' : '';
  document.querySelectorAll('input[type="text"], input[type="email"], input[type="tel"], textarea').forEach(el => {
    el.dir = lang === 'ar' ? 'rtl' : 'ltr';
  });
}
setLang('en');

document.getElementById('partner-form').addEventListener('submit', async function(e) {
  e.preventDefault();
  // Generate a random fbzx session ID (matches Google Forms format)
  const fbzx = (Math.floor(Math.random() * 9e18) - 4.5e18).toFixed(0);
  document.getElementById('fbzx').value = fbzx;
  document.getElementById('partialResponse').value = '[null,null,"' + fbzx + '"]';

  const btn = document.querySelector('.btn-submit');
  const origHTML = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<span class="lang-en">Submitting…</span><span class="lang-ar">جارٍ الإرسال…</span>';
  // re-apply lang visibility after innerHTML change
  document.querySelectorAll('.btn-submit .lang-en, .btn-submit .lang-ar').forEach(el => {
    const cls = el.className.replace('lang-', '');
    el.style.display = document.body.className === cls ? '' : 'none';
  });

  try {
    // Build URLSearchParams (Google Forms requires application/x-www-form-urlencoded)
    const params = new URLSearchParams();
    new FormData(this).forEach((val, key) => params.append(key, val));

    await fetch('https://docs.google.com/forms/u/0/d/e/1FAIpQLScsxpfs4RKVwsHzimNzj0xXjxaXaMSIGjxcyil3as4Xv7qcJA/formResponse', {
      method: 'POST',
      body: params,
      mode: 'no-cors',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' }
    });
    document.getElementById('success-overlay').classList.add('show');
    this.reset();
  } catch(err) {
    alert('Submission failed. Please try again.');
  } finally {
    btn.disabled = false;
    btn.innerHTML = origHTML;
    setLang(document.body.className);
  }
});
</script>
